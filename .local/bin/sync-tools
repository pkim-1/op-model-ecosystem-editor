#!/bin/bash
set -e

TOOLS_REPO="/Users/paulkim/tools"
HOME_DIR="/Users/paulkim"

# Color codes for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Function: normalize name to kebab-case
normalize_name() {
    local name="$1"
    echo "$name" | tr '[:upper:]' '[:lower:]' | sed 's/[_ ]/-/g'
}

# Function: detect HTML files in home directory (max depth 1)
detect_html_files() {
    find "$HOME_DIR" -maxdepth 1 -type f -name "*.html" 2>/dev/null || true
}

# Function: detect dashboard directories (requirements.txt + .py files)
detect_dashboard_dirs() {
    local dirs=()
    while IFS= read -r dir; do
        if [[ -f "$dir/requirements.txt" ]] && find "$dir" -maxdepth 1 -name "*.py" -print -quit | grep -q .; then
            dirs+=("$dir")
        fi
    done < <(find "$HOME_DIR" -maxdepth 1 -type d ! -name ".*" ! -path "$HOME_DIR" 2>/dev/null || true)

    printf '%s\n' "${dirs[@]}"
}

# Function: check if already synced
is_already_synced() {
    local category="$1"
    local normalized_name="$2"

    if [[ "$category" == "presentation" ]]; then
        [[ -f "$TOOLS_REPO/presentations/$normalized_name" ]]
    elif [[ "$category" == "dashboard" ]]; then
        [[ -d "$TOOLS_REPO/dashboards/$normalized_name" ]]
    else
        return 1
    fi
}

# Function: display summary table
display_summary() {
    local -n items=$1

    if [[ ${#items[@]} -eq 0 ]]; then
        return
    fi

    echo ""
    echo "=== Tools to Sync ==="
    echo ""
    printf "%-12s %-40s %-30s\n" "Category" "Source" "Target"
    printf "%-12s %-40s %-30s\n" "--------" "------" "------"

    for item in "${items[@]}"; do
        IFS='|' read -r category source target <<< "$item"
        printf "%-12s %-40s %-30s\n" "$category" "$(basename "$source")" "$target"
    done
    echo ""
}

# Function: copy files and commit
copy_and_commit() {
    local -n items=$1
    local commit_msg="add:"
    local added_files=()

    cd "$TOOLS_REPO" || exit 1

    for item in "${items[@]}"; do
        IFS='|' read -r category source target <<< "$item"

        if [[ "$category" == "presentation" ]]; then
            cp "$source" "$TOOLS_REPO/presentations/$target"
            git add "presentations/$target"
            added_files+=("presentations/$target")
            commit_msg="$commit_msg $target"
        elif [[ "$category" == "dashboard" ]]; then
            cp -r "$source" "$TOOLS_REPO/dashboards/$target"
            git add "dashboards/$target"
            added_files+=("dashboards/$target")
            commit_msg="$commit_msg $target"
        fi
    done

    # Create commit
    git commit -m "$commit_msg" >/dev/null 2>&1

    # Push to GitHub
    if ! git push origin main 2>&1; then
        echo -e "${RED}Error: Failed to push to GitHub${NC}"
        echo "Local files have been copied and committed, but not pushed."
        echo "Run 'cd $TOOLS_REPO && git push' to retry."
        return 1
    fi

    # Display success summary
    echo ""
    echo "=== Sync Summary ==="
    echo -e "${GREEN}Added:${NC}"
    for file in "${added_files[@]}"; do
        echo "  - $file"
    done
    echo ""
    echo -e "${GREEN}Committed and pushed to GitHub.${NC}"
    echo ""

    # Suggested README entries
    echo "Suggested README entry:"
    for item in "${items[@]}"; do
        IFS='|' read -r category source target <<< "$item"
        local display_name=$(echo "$target" | sed 's/-/ /g' | sed 's/\b\(.\)/\u\1/g')

        if [[ "$category" == "presentation" ]]; then
            echo "- [$display_name](presentations/$target) - [Add description]"
        elif [[ "$category" == "dashboard" ]]; then
            echo "- [$display_name](dashboards/$target/) - [Add description]"
        fi
    done
    echo ""
}

# Main execution
main() {
    # Handle --test-normalize flag for verification
    if [[ "$1" == "--test-normalize" && -n "$2" ]]; then
        normalize_name "$2"
        exit 0
    fi

    # Handle --dry-run flag
    local dry_run=false
    if [[ "$1" == "--dry-run" ]]; then
        dry_run=true
    fi

    # Check if tools repo exists
    if [[ ! -d "$TOOLS_REPO" ]]; then
        echo -e "${RED}Error: tools repo not found at $TOOLS_REPO${NC}"
        exit 1
    fi

    # Detect new tools
    local items_to_sync=()

    # Detect HTML files
    while IFS= read -r html_file; do
        [[ -z "$html_file" ]] && continue

        local basename=$(basename "$html_file")
        local normalized=$(normalize_name "$basename")

        if ! is_already_synced "presentation" "$normalized"; then
            items_to_sync+=("presentation|$html_file|$normalized")
        fi
    done < <(detect_html_files)

    # Detect dashboard directories
    while IFS= read -r dir; do
        [[ -z "$dir" ]] && continue

        local dirname=$(basename "$dir")
        local normalized=$(normalize_name "$dirname")

        if ! is_already_synced "dashboard" "$normalized"; then
            items_to_sync+=("dashboard|$dir|$normalized")
        fi
    done < <(detect_dashboard_dirs)

    # Check if any tools found
    if [[ ${#items_to_sync[@]} -eq 0 ]]; then
        echo "No new tools found to sync."
        exit 0
    fi

    # Display summary
    display_summary items_to_sync

    # Dry run mode - exit after showing summary
    if [[ "$dry_run" == true ]]; then
        echo "(Dry run - no changes made)"
        exit 0
    fi

    # Confirmation prompt
    read -p "Proceed with sync? (y/N): " -n 1 -r
    echo ""

    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Sync cancelled."
        exit 0
    fi

    # Execute sync
    copy_and_commit items_to_sync
}

# Run main function
main "$@"
